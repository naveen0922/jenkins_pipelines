pipeline {
    agent any

    triggers {
        cron('H/5 * * * *')
    }

    options {
        // ansiColor('xterm')  // for colored output in console
        disableConcurrentBuilds(abortPrevious: true)
        buildDiscarder(logRotator(numToKeepStr: '2'))
        disableResume()
        timeout(time: 2, unit: 'MINUTES')
    }
    environment {
        CURRENT_ENV = 'prodaa'
    }
    stages {
        stage('CHECKOUT_REPOA') {
            steps {
                checkout ([ $class: 'GitSCM', 
                            branches: [[name: '*/main']], 
                            extensions: [], 
                            userRemoteConfigs: [[
                                credentialsId: 'hp-git', 
                                url: 'https://github.com/naveen0922/self.git'
                            ]]
                        ])
                sh '''
                    echo GIT_BRANCH: ${GIT_BRANCH}
                    echo BRANCH_NAME: ${BRANCH_NAME}
                '''
            }
        }
        stage('STAGE1 when branch') {
            when {
                branch 'main'
            }
            steps {
                echo "This is the step 1"
                sh '''
                    pwd
                    ls -lrt
                    sleep 5
                   
                '''
                echo"\033[33m This is the colored output in console \033[0m"
            }
        }
    }
}

    