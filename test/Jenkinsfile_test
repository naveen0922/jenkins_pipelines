pipeline {
    agent any
    

    stages {
        stage('STAGE1a') {
            steps {
                catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {
                    echo "This is the step 1"
                    sh '''
                        sleep 5
                        exit 1
                    '''
                }
            }
        } 

        stage('STAGE1b') {
            steps {
                script {
                    try {
                        sh '''
                            sleep 5
                            exit 1
                        '''
                    }
                    catch(err) {
                        echo "Error caught: ${err}"
                        currentBuild.result = 'SUCCESS'
                        currentStage.result = 'FAILURE'
                    }
                }
            }
        }
        
        stage('PARALLEL TESTING') {
            parallel {
                stage('WINDOWS TESTING') {
                    steps {
                        echo "This is the windows testing"
                        sh 'sleep 5'
                    }
                }
                stage('mac') {
                    steps {
                        echo "This is the mac testing"
                        sh 'sleep 5'
                    }

                }
            }
        }
        stage('FINAL STAGE') {
            steps {
                echo "This is the final stage"
            }
        } 
    
    }
}